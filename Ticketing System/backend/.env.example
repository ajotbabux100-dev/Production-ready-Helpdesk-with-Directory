# SECURITY: set to True only for local development. DEBUG=True on a
# reachable deployment leaks full stack traces (including local variable
# values - e.g. SMTP passwords, the vault key - if an error happens near
# them) to anyone who can trigger a 500.
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True once this app is served over HTTPS - enables HSTS and marks
# session/CSRF cookies Secure. Leave False for local/plain-HTTP LAN use.
USE_HTTPS=False

# Database
DB_NAME=ticketing_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email (Microsoft 365)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Helpdesk <your-email@yourdomain.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Password Vault encryption key - generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key
